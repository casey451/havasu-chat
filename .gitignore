# Local env files (secrets); .env.example template may be tracked
.env
.env.*
!.env.example
.claude/
search_debug.log
*.db
__pycache__/
*.pyc
.pytest_cache/

# Local-only session notes (not durable project artifacts)
docs/phase2-assistant-log.md

# Windows shortcut dropped in docs by mistake
docs/*Shortcut*.lnk

# Script-generated local extracts (do not commit)
scripts/output/

diag.json
tmp/
scratch/

# Chat-exported Cursor prompt copies (canonical versions are tracked separately)
docs/phase-*-cursor-prompt-chat-export.md

# Cursor handback and pre-flight-stop reports (scratch, not permanent)
docs/phase-*-handback-*.md
docs/phase-*-preflight-stop-*.md

# Chat-relay artifacts (HALT transcripts, status reports, etc.)
# See relay/README.md for context. Must un-ignore `relay/` before a file inside it can be tracked.
relay/**
!relay/
!relay/README.md
scripts/confabulation_eval_results/*
!scripts/confabulation_eval_results/baselines/
